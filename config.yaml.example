# Aion v0.3.0 — ~/.aion/config.yaml
model: claude-sonnet-4-20250514
max_turns: 100
permission_mode: bypassPermissions

memory:
  char_limit: 2200
  user_char_limit: 1375

audit:
  enabled: true
  log_tool_calls: true
  redact_secrets: true

